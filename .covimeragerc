# .coveragerc to control coverage.py
[run]
# branch = True
source = panvimwiki
plugins = covimerage
data_file = .coverage_covimerage
# omit =
# disable_warnings = include-ignored

[paths]
source =
    src/
    */site-packages/
    autoload/
    plugin/
    after/
    tests/

[report]
# Regexes for lines to exclude from consideration
# exclude_lines =
omit =
    tests/vim/bundle/*
    tests/vim/vimrc
show_missing = true
